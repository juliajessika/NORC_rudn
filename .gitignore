# =========================
# Local configs
# =========================
configs/*.yml
!configs/*.example.yml
configs/*.yaml
!configs/*.example.yaml

# =========================
# DVC
# =========================
.dvc/tmp/
.dvc/cache/
.dvc/config.local

# DVC pointer files should be tracked
!*.dvc

# =========================
# Workflow outputs
# =========================
runs/
outputs/
exports/
tiles_roi/
deepcell_output/
cellsighter_export/
ground_truth/

# QuPath temporary/export folders
qupath_export/
qupath_import/
tiles/
masks/
polygons/
predictions/

# =========================
# Microscopy / image data
# =========================
*.svs
*.ndpi
*.czi
*.lif
*.scn
*.vsi
*.mrxs
*.ome.tif
*.ome.tiff

# Large TIFFs are usually data, not code
*.tif
*.tiff

# But allow tiny examples if you intentionally add them
!examples/**/*.tif
!examples/**/*.tiff

# =========================
# Model weights / checkpoints
# Track these with DVC, not Git
# =========================
*.h5
*.weights.h5
*.keras
*.pth
*.pt
*.ckpt
*.onnx
*.pkl
*.joblib

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

*.egg-info/
.eggs/
build/
dist/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# =========================
# Logs / temporary files
# =========================
logs/
tmp/
temp/
*.log

wandb/
lightning_logs/
tensorboard/

# =========================
# OS / IDE
# =========================
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
