FROM python:3.9-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip setuptools wheel

# TensorFlow + DeepCell stack
# If your current training env used slightly different versions,
# change them here to match.
RUN pip install \
    numpy==1.23.5 \
    tifffile==2023.7.10 \
    scikit-image==0.19.3 \
    tensorflow==2.8.4 \
    deepcell==0.12.6



COPY preload_model.py /app/preload_model.py
COPY segment_tiles.py /app/segment_tiles.py

# This step downloads and caches the pretrained DeepCell model
RUN python /app/preload_model.py

ENTRYPOINT ["python", "/app/segment_tiles.py"]
